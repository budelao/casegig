{
  "ConnectionStrings": {
    "MySql": "server=localhost;port=3306;database=casegig;user=root;password=root;AllowUserVariables=True"
  },
  "Logging": {
    "Console": {
      "FormatterName": "pretty",
      "UseColors": true,
      "ForceColors": true,
      "ColorMode": "ansi"
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Worker": {
    "IntervalSeconds": 10,
    "BatchSize": 20
  },
  "Observability": {
    "Logging": {
      "Enabled": true,
      "AddCorrelationIdHeader": true,
      "ServiceName": "CaseGig.Api",
      "LogRequestHeaders": false,
      "RequestHeaderAllowList": [],
      "LogResponseHeaders": false,
      "ResponseHeaderAllowList": [],
      "Export": {
        "Splunk": {
          "Enabled": false,
          "HecEndpoint": "",
          "Token": "CHANGE_ME",
          "Index": "",
          "SourceType": ""
        },
        "Grafana": {
          "Enabled": false,
          "LokiEndpoint": "",
          "Token": "CHANGE_ME"
        },
        "Datadog": {
          "Enabled": false,
          "Site": "datadoghq.com",
          "ApiKey": "CHANGE_ME",
          "Service": "CaseGig.Api",
          "Environment": "Development"
        }
      }
    }
  },
  "AllowedHosts": "*"
}
